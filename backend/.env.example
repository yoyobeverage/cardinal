# Copy to .env and fill in real values. Do NOT commit .env.

# Qdrant Cloud (https://cloud.qdrant.io)
QDRANT_URL=https://your-cluster-id.cloud.qdrant.io:6333
QDRANT_API_KEY=

# Primary LLM provider: Google AI Studio (https://aistudio.google.com/app/apikey)
# Free tier covers hackathon usage.
GOOGLE_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Secondary LLM provider: Groq (https://console.groq.com) - OPTIONAL.
# When set, app.llm's layered chain tries Gemini first, then Llama 3.3 70B
# on Groq, then Llama 3.1 8B on Groq, and only falls back to a deterministic
# template if all three LLM calls fail. Free tier covers hackathon usage.
GROQ_API_KEY=
GROQ_MODEL_PRIMARY=llama-3.3-70b-versatile
GROQ_MODEL_FAST=llama-3.1-8b-instant

# Hard timeout (seconds) per LLM call before moving to the next layer.
LLM_TIMEOUT_S=10.0

# Collection name
QDRANT_COLLECTION=cardinal-hackathon-project
